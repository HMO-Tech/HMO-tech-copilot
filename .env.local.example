# ============================================
# D&T Ai-TECH Platform - Environment Variables
# ============================================

# OpenRouter API for AI Engine
# Get your key at: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# GitHub API Token for Artifact Management
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Application Settings
NEXT_PUBLIC_APP_NAME=D&T Ai-TECH
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GitHub Repository for Outputs
GITHUB_OWNER=HMO-Tech
GITHUB_REPO=D-T-Ai-Outputs
GITHUB_BRANCH=main

# AI Engine Configuration
AI_MODEL=openai/gpt-4o-mini
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=1500

# Workflow Engine Settings
WORKFLOW_TIMEOUT=30000
ARTIFACT_STORAGE=github
